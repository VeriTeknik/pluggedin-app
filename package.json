    "db:push:dev": "drizzle-kit push",
    "db:migrate:auth": "tsx scripts/apply-migrations.js",
    "db:fix:fk": "tsx scripts/add-missing-fk.ts",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major",
    "postversion": "git push && git push --tags",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:encryption": "tsx scripts/migrate-encryption.ts",
    "migrate:encryption:dry": "tsx scripts/migrate-encryption.ts --dry",
    "setup:email-consents": "tsx scripts/setup-email-consents.ts",
    "setup:email-consents:dry": "tsx scripts/setup-email-consents.ts --dry",
    "knip": "knip",
